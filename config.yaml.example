listen: "127.0.0.1:11435"

upstream: "https://ollama.com/v1"

proxy:
  http: "${http_proxy}"
  https: "${https_proxy}"
  no_proxy: "localhost,127.0.0.1"

keys:
  - "${OLLAMA_API_KEY_1}"
  - "${OLLAMA_API_KEY_2}"

cooldown:
  session_limit_hours: 72
  rate_limit_hours: 4

admin:
  username: "admin"
  password: "changeme"
  session_secret: "change-me-to-random-secret"

admin:
  username: "admin"
  password: "${ADMIN_PASSWORD}"
  session_secret: "${ADMIN_SESSION_SECRET}"
